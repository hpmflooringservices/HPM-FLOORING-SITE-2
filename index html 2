<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
font-family:'Inter',sans-serif;
background:#f5f5f5;
color:#111;
overflow-x:hidden;
}

.container{
width:92%;
max-width:1400px;
margin:auto;
}

header{
background:#fff;
padding:16px 0;
border-bottom:1px solid #ddd;
position:sticky;
top:0;
z-index:999;
}

.nav{
display:flex;
justify-content:space-between;
align-items:center;
gap:20px;
flex-wrap:wrap;
}

.logo img{
height:70px;
}

nav{
display:flex;
gap:28px;
flex-wrap:wrap;
}

nav a{
text-decoration:none;
color:#111;
font-weight:600;
}

.call-btn{
background:#ff6a00;
color:#fff;
padding:14px 22px;
border-radius:10px;
text-decoration:none;
font-weight:700;
}

.hero{
position:relative;
min-height:780px;
display:flex;
align-items:center;
background:url('https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?q=80&w=1800&auto=format&fit=crop') center/cover;
}

.overlay{
position:absolute;
inset:0;
background:linear-gradient(to right, rgba(0,0,0,.82), rgba(0,0,0,.3));
}

.hero-content{
position:relative;
z-index:2;
display:grid;
grid-template-columns:1.2fr 420px;
gap:40px;
align-items:center;
width:100%;
}

.hero-left{
color:#fff;
}

.hero-left h1{
font-size:4.5rem;
line-height:1;
font-weight:800;
margin-bottom:24px;
}

.orange{
color:#ff6a00;
}

.hero-left p{
font-size:1.1rem;
max-width:650px;
margin-bottom:30px;
line-height:1.7;
}

.hero-buttons{
display:flex;
gap:16px;
flex-wrap:wrap;
margin-bottom:30px;
}

.btn{
padding:16px 24px;
border-radius:10px;
text-decoration:none;
font-weight:700;
display:inline-block;
}

.btn-orange{
background:#ff6a00;
color:#fff;
}

.btn-outline{
border:1px solid rgba(255,255,255,.5);
color:#fff;
}

.features{
display:flex;
gap:30px;
flex-wrap:wrap;
font-weight:600;
}

.quote-box{
background:#fff;
padding:30px;
border-radius:18px;
box-shadow:0 20px 50px rgba(0,0,0,.2);
}

.quote-box h2{
font-size:2rem;
margin-bottom:10px;
text-align:center;
}

.quote-box p{
text-align:center;
color:#666;
margin-bottom:20px;
}

form{
display:grid;
gap:14px;
}

input,
textarea,
select{
padding:15px;
border-radius:10px;
border:1px solid #ddd;
font-size:1rem;
font-family:inherit;
width:100%;
}

textarea{
min-height:120px;
resize:vertical;
}

button{
border:none;
cursor:pointer;
}

.services{
padding:80px 0;
background:#f7f7f7;
}

.section-title{
text-align:center;
margin-bottom:50px;
}

.section-title p{
color:#ff6a00;
font-weight:700;
margin-bottom:8px;
}

.section-title h2{
font-size:2.5rem;
}

.services-grid{
display:grid;
grid-template-columns:repeat(3,1fr);
gap:22px;
}

.card{
background:#fff;
border-radius:18px;
overflow:hidden;
box-shadow:0 5px 20px rgba(0,0,0,.05);
}

.card img{
width:100%;
height:220px;
object-fit:cover;
}

.card-content{
padding:22px;
}

.card-content h3{
margin-bottom:10px;
font-size:1.2rem;
}

.card-content p{
color:#666;
line-height:1.7;
}

.about{
padding:80px 0;
background:#fff;
}

.about-grid{
display:grid;
grid-template-columns:1fr 1fr;
gap:40px;
align-items:center;
}

.about-box{
background:#111;
color:#fff;
padding:40px;
border-radius:20px;
}

.about-box h3{
font-size:2rem;
margin-bottom:20px;
}

.about-list{
display:grid;
gap:14px;
}

footer{
background:#111;
color:#fff;
padding:40px 0;
margin-top:60px;
}

.footer-grid{
display:flex;
justify-content:space-between;
gap:30px;
flex-wrap:wrap;
align-items:center;
}

.footer-logo img{
height:70px;
margin-bottom:10px;
}

@media(max-width:1100px){
.hero-content{
grid-template-columns:1fr;
padding:60px 0;
}

.hero-left h1{
font-size:3.2rem;
}

.services-grid{
grid-template-columns:repeat(2,1fr);
}

.about-grid{
grid-template-columns:1fr;
}
}

@media(max-width:700px){
nav{
display:none;
}

.hero{
min-height:auto;
padding:40px 0;
}

.hero-left h1{
font-size:2.3rem;
}

.hero-buttons{
flex-direction:column;
}

.btn{
width:100%;
text-align:center;
}

.features{
flex-direction:column;
gap:14px;
}

.services-grid{
grid-template-columns:1fr;
}

.quote-box{
padding:24px;
}

.call-btn{
width:100%;
text-align:center;
}
}
</style>
</head>

